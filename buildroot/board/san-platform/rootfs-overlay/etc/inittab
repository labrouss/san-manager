# /etc/inittab — BusyBox init configuration
#
# Format: id:runlevels:action:process

# Boot sequence
::sysinit:/etc/init.d/rcS

# Restart init if it exits
::ctrlaltdel:/sbin/reboot

# VGA console login on tty1 (the main monitor/framebuffer)
tty1::respawn:/sbin/getty -L tty1 115200 vt100

# Serial console login on ttyS0 (COM1) — useful for remote/headless access
ttyS0::respawn:/sbin/getty -L ttyS0 115200 vt100

# Shutdown actions
::shutdown:/etc/init.d/rcK
::shutdown:/sbin/swapoff -a
::shutdown:/bin/umount -a -r
