# =============================================================================
# buildroot/configs/san_platform_defconfig
#
# Buildroot 2024.02.x configuration for the SAN Management Platform OVA.
#
# Target:  x86_64 PC (BIOS + UEFI via GRUB2)
# libc:    musl  (small, Docker-compatible)
# Init:    systemd (required by Docker Engine)
# Kernel:  Linux 6.6 LTS (BR2_LINUX_KERNEL_LATEST_LTS_VERSION)
#
# Validated against Buildroot 2024.02.9 Kconfig symbols.
# Run `make savedefconfig` after any menuconfig changes to keep this in sync.
# =============================================================================

# ── Architecture ──────────────────────────────────────────────────────────────
BR2_x86_64=y
# BR2_x86_64_v2 is not a Buildroot symbol — use TARGET_OPTIMIZATION instead
BR2_TARGET_OPTIMIZATION="-O2 -pipe -march=x86-64-v2"

# ── Toolchain ─────────────────────────────────────────────────────────────────
BR2_TOOLCHAIN_BUILDROOT_MUSL=y
BR2_TOOLCHAIN_BUILDROOT_CXX=y
# GCC 13.2 and binutils 2.41 ship in Buildroot 2024.02
BR2_GCC_VERSION_13_X=y
BR2_BINUTILS_VERSION_2_41_X=y

# ── System ────────────────────────────────────────────────────────────────────
BR2_SYSTEM_DHCP="eth0"
BR2_TARGET_GENERIC_HOSTNAME="san-platform"
BR2_TARGET_GENERIC_ISSUE="SAN Management Platform"
BR2_TARGET_TZ_INFO=y
BR2_TARGET_LOCALTIME="UTC"

# ── Init system (systemd — required by Docker Engine) ─────────────────────────
BR2_INIT_SYSTEMD=y
BR2_PACKAGE_SYSTEMD=y
BR2_PACKAGE_SYSTEMD_NETWORKD=y
BR2_PACKAGE_SYSTEMD_RESOLVED=y

# ── Kernel ────────────────────────────────────────────────────────────────────
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_LATEST_LTS_VERSION=y
BR2_LINUX_KERNEL_USE_DEFCONFIG=y
BR2_LINUX_KERNEL_DEFCONFIG="x86_64"
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_SAN_PLATFORM_PATH)/board/san-platform/linux-docker.fragment"
BR2_LINUX_KERNEL_NEEDS_HOST_OPENSSL=y

# ── Bootloader (GRUB2 — BIOS + UEFI) ─────────────────────────────────────────
BR2_TARGET_GRUB2=y
BR2_TARGET_GRUB2_I386_PC=y
BR2_TARGET_GRUB2_X86_EFI=y

# ── Root filesystem ───────────────────────────────────────────────────────────
BR2_TARGET_ROOTFS_EXT2=y
BR2_TARGET_ROOTFS_EXT2_4=y
BR2_TARGET_ROOTFS_EXT2_SIZE="3072M"
BR2_ROOTFS_OVERLAY="$(BR2_EXTERNAL_SAN_PLATFORM_PATH)/board/san-platform/rootfs-overlay"
BR2_ROOTFS_POST_BUILD_SCRIPT="$(BR2_EXTERNAL_SAN_PLATFORM_PATH)/board/san-platform/post-build.sh"
BR2_ROOTFS_POST_IMAGE_SCRIPT="$(BR2_EXTERNAL_SAN_PLATFORM_PATH)/board/san-platform/post-image.sh"

# ── Disk image (host genimage tool) ──────────────────────────────────────────
BR2_PACKAGE_HOST_GENIMAGE=y

# ── Core utilities ────────────────────────────────────────────────────────────
BR2_PACKAGE_BUSYBOX=y
BR2_PACKAGE_BASH=y
BR2_PACKAGE_CURL=y
BR2_PACKAGE_CA_CERTIFICATES=y
BR2_PACKAGE_OPENSSL=y
# openssh: server + client are both included with this single option
# BR2_PACKAGE_OPENSSH_SERVER is not a sub-option — removed
BR2_PACKAGE_OPENSSH=y

# ── Filesystem & disk tools ───────────────────────────────────────────────────
BR2_PACKAGE_E2FSPROGS=y
BR2_PACKAGE_E2FSPROGS_RESIZE2FS=y
BR2_PACKAGE_PARTED=y
BR2_PACKAGE_UTIL_LINUX=y
BR2_PACKAGE_UTIL_LINUX_MOUNT=y

# ── Networking ────────────────────────────────────────────────────────────────
# iptables includes ip6tables in Buildroot 2024.02 (merged — BR2_PACKAGE_IP6TABLES removed)
BR2_PACKAGE_IPTABLES=y
BR2_PACKAGE_IPROUTE2=y
BR2_PACKAGE_NFTABLES=y
BR2_PACKAGE_BRIDGE_UTILS=y

# ── Container runtime ─────────────────────────────────────────────────────────
# BR2_PACKAGE_DOCKER_ENGINE pulls in containerd + runc automatically.
# BR2_PACKAGE_DOCKER_ENGINE_DRIVER_OVERLAY2 was removed in 2023 — overlay2
# is always compiled in since then.
BR2_PACKAGE_DOCKER_ENGINE=y
BR2_PACKAGE_DOCKER_CLI=y
BR2_PACKAGE_DOCKER_COMPOSE=y

# ── Time sync ─────────────────────────────────────────────────────────────────
BR2_PACKAGE_CHRONY=y

# ── Ops tooling (available over SSH) ─────────────────────────────────────────
BR2_PACKAGE_HTOP=y
BR2_PACKAGE_LESS=y
BR2_PACKAGE_VIM_TINY=y
BR2_PACKAGE_JQ=y

# ── Host-side build tools ─────────────────────────────────────────────────────
BR2_PACKAGE_HOST_DOSFSTOOLS=y
BR2_PACKAGE_HOST_MTOOLS=y
BR2_PACKAGE_HOST_PARTED=y

# ── Build cache ───────────────────────────────────────────────────────────────
# CCACHE_DIR is set via env var in the CI workflow ($(HOME) is not valid here)
BR2_CCACHE=y
